{
  "manifest_version": 3,
  "name": "かんたん画像変換",
  "version": "1.2.0",
  "description": "Webページの画像を右クリックでJPG・PNG・WebPに変換して保存できるブラウザ拡張機能（Chrome・Firefox対応）",
  "permissions": [
    "contextMenus",
    "downloads",
    "activeTab",
    "scripting"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "kantan-image-converter@takumi0213.github.io",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": ["technicalAndInteraction"]
      }
    }
  },
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "かんたん画像変換",
    "default_popup": "docs/popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
