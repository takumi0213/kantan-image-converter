{
  "manifest_version": 3,
  "name": "かんたん画像変換",
  "version": "1.0.0",
  "description": "Webページの画像を右クリックでJPG・PNG・WebPに変換して保存できるChrome拡張機能",
  "permissions": [
    "contextMenus",
    "downloads",
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "かんたん画像変換",
    "default_popup": "docs/popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}